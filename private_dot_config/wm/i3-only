# i3-only config (X11-specific)
# Included by ~/.config/i3/config

# Emergency exit for frozen applications (X11)
bindsym $mod+Shift+Escape exec --no-startup-id xkill
bindsym $mod+Ctrl+x --release exec --no-startup-id xkill

# Clipboard manager (X11)
bindsym $mod+z exec --no-startup-id clipmenu -i -fn Terminus:size=8 -nb '#002b36' -nf '#839496' -sb '#073642' -sf '#93a1a1'

# Application launcher (X11)
bindsym $mod+d exec /home/$USER/.config/scripts/dmenu_recency

# Keyboard layout (X11)
exec --no-startup-id setxkbmap -layout se -variant US_swe
bindsym $mod+Shift+u exec setxkbmap -layout se
bindsym $mod+u exec setxkbmap -layout se -variant US_swe

# Compositor (X11)
bindsym $mod+t exec --no-startup-id pkill compton
bindsym $mod+Ctrl+t exec --no-startup-id compton -b

# Screenshots (X11)
bindsym Print exec "env QT_AUTO_SCREEN_SCALE_FACTOR=1.5 QT_SCREEN_SCALE_FACTORS= flameshot gui"
bindsym --release Print exec scrot 'screenshot_%Y%m%d_%H%M%S.png' -e 'mkdir -p ~/Pictures/screenshots && mv $f ~/Pictures/screenshots && xclip -selection clipboard -t image/png -i ~/Pictures/screenshots/`ls -1 -t ~/Pictures/screenshots | head -1`'
bindsym --release Shift+Print exec scrot -s 'screenshot_%Y%m%d_%H%M%S.png' -e 'mkdir -p ~/Pictures/screenshots && mv $f ~/Pictures/screenshots && xclip -selection clipboard -t image/png -i ~/Pictures/screenshots/`ls -1 -t ~/Pictures/screenshots | head -1`'

# restart i3 inplace (preserves your layout/session)
bindsym $mod+Shift+r restart

# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

# Lock screen (X11)
bindsym $mod+Shift+x exec /home/$USER/.config/scripts/lock
bindsym $mod+F12 exec i3lock-fancy
exec --no-startup-id xss-lock --transfer-sleep-lock -- /home/$USER/.config/scripts/lock
exec --no-startup-id xautolock -time 10 -locker blurlock

# Optimus / prime-offloading (X11)
exec --no-startup-id "prime-offload"

# Monitor setup (X11 / xrandr)
exec --no-startup-id ~/.local/bin/monitor-setup

# Workspace output assignments (X11 output names)
workspace 1 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 2 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 3 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 4 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 5 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 6 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 7 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 8 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 9 output DP-3 DP-2 DP-1 HDMI-1 eDP-1
workspace 0 output eDP-1

# X11 autostart
exec --no-startup-id nm-applet
exec --no-startup-id volumeicon
exec --no-startup-id clipmenud
exec --no-startup-id nitrogen --restore; sleep 1; compton -b
exec --no-startup-id start_conky_maia
exec_always --no-startup-id ff-theme-util
exec_always --no-startup-id fix_xcursor
exec_always --no-startup-id "killall xbindkeys; xbindkeys"

# Xresources color palette (available for future use)
set_from_resource $term_background background
set_from_resource $term_foreground foreground
set_from_resource $term_color0     color0
set_from_resource $term_color1     color1
set_from_resource $term_color2     color2
set_from_resource $term_color3     color3
set_from_resource $term_color4     color4
set_from_resource $term_color5     color5
set_from_resource $term_color6     color6
set_from_resource $term_color7     color7
set_from_resource $term_color8     color8
set_from_resource $term_color9     color9
set_from_resource $term_color10    color10
set_from_resource $term_color11    color11
set_from_resource $term_color12    color12
set_from_resource $term_color13    color13
set_from_resource $term_color14    color14
set_from_resource $term_color15    color15
