# Sway-only config (Wayland-specific)
# Included by ~/.config/sway/config

# Keyboard layout (Wayland — replaces setxkbmap)
input type:keyboard {
    xkb_layout se
    xkb_variant US_swe
}
bindsym $mod+Shift+u input type:keyboard xkb_variant ""
bindsym $mod+u input type:keyboard xkb_variant "US_swe"

# Application launcher (Wayland)
bindsym $mod+d exec fuzzel

# Clipboard manager (Wayland — requires cliphist + wl-copy)
bindsym $mod+z exec cliphist list | fuzzel -d | cliphist decode | wl-copy

# Screenshots (Wayland — requires grim, slurp, wl-copy)
# Full screen capture
bindsym Print exec grim - | wl-copy && grim ~/Pictures/screenshots/screenshot_$(date +%Y%m%d_%H%M%S).png
# Area selection
bindsym Shift+Print exec grim -g "$(slurp)" - | wl-copy && grim -g "$(slurp)" ~/Pictures/screenshots/screenshot_$(date +%Y%m%d_%H%M%S).png

# Reload sway config (Sway doesn't have "restart", only "reload")
bindsym $mod+Shift+r reload

# Exit sway
bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -b 'Yes, exit sway' 'swaymsg exit'

# Network manager tray (needs --indicator for Wayland tray protocol)
exec nm-applet --indicator

# Notification daemon
exec mako

# Float browser notification popups that bypass mako
for_window [app_id="chrome-.*"] floating enable
for_window [title=".*— Indicator.*"] floating enable

output DP-7 scale 1.5
output * bg ~/Downloads/DSC_0244.jpg fill

