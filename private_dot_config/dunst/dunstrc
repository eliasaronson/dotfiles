[global]
    # Follow keyboard focus so notifications appear on the active monitor
    follow = keyboard

    # Position: top-right corner
    origin = top-right
    offset = 10x50

    # Width and height
    width = 300
    height = (0, 300)

    # Auto-hide notifications after 5 seconds
    timeout = 5

    # Styling
    font = URWGothic-Book 10
    frame_width = 2
    frame_color = "#556064"
    separator_color = frame
    corner_radius = 4

    # Prevent notification spam
    indicate_hidden = yes
    stack_duplicates = true

    # Match i3 theme colors
    background = "#222D31"
    foreground = "#F9FAF9"

[urgency_low]
    timeout = 3

[urgency_normal]
    timeout = 5

[urgency_critical]
    timeout = 0
    frame_color = "#CB4B16"
